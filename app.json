{
  "expo": {
    "name": "Guilt Giver",
    "slug": "guiltGiver",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/icon.png",
    "scheme": "guiltgiver",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.armita2003.guiltGiver",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },

      "predictiveBackGestureEnabled": false,
      "package": "com.armita2003.guiltGiver"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "splash": {
        "image": "./assets/images/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#208AEF"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Guilt Giver to access your photos to analyze meals.",
          "cameraPermission": "Allow Guilt Giver to use your camera to analyze meals."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7441b04-69de-46ef-9ec0-1e8072c49ee9"
      }
    }
  }
}
